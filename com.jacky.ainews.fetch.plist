<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jacky.ainews.fetch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/jacky/CatPaw Desk/daily-news/fetch_news.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/jacky/CatPaw Desk/daily-news</string>

    <!-- 每天早上 8:00 自动抓取 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 日志 -->
    <key>StandardOutPath</key>
    <string>/Users/jacky/CatPaw Desk/daily-news/logs/fetch.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jacky/CatPaw Desk/daily-news/logs/fetch.error.log</string>
</dict>
</plist>
